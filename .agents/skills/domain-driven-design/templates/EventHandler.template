namespace Modules\{Module}\Application\EventHandlers;

use Modules\{Module}\Application\DTOs\{Name}DTO;
use Modules\{Module}\Domain\Actions\{Action}Action;
use Modules\{SourceModule}\Domain\Events\{EventName};

class {EventName}Handler
{
    public function __construct(
        private readonly {Action}Action $action,
    ) {}

    public function handle({EventName} $event): void
    {
        // Guard against duplicate delivery before processing.
        $dto = new {Name}DTO(
            id: $event->entityId,
        );

        $this->action->execute($dto);
    }
}
