namespace Modules\{Module}\Interfaces\Controllers;

use Illuminate\Http\JsonResponse;
use Modules\{Module}\Application\DTOs\{Name}DTO;
use Modules\{Module}\Application\UseCases\{Name}UseCase;
use Modules\{Module}\Interfaces\Requests\{Name}Request;

class {Name}Controller
{
    public function __construct(
        private readonly {Name}UseCase $useCase,
    ) {}

    public function __invoke({Name}Request $request): JsonResponse
    {
        $dto = {Name}DTO::fromRequest($request);

        $result = $this->useCase->handle($dto);

        return response()->json($result, 200);
    }
}
