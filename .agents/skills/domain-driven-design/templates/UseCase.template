<?php declare(strict_types=1);

namespace Modules\{Module}\Application\UseCases;

use Modules\{Module}\Application\DTOs\{Name}DTO;
use Modules\{Module}\Domain\Actions\{Action}Action;
use Modules\{Module}\Domain\Entities\{Entity};

class {Name}UseCase
{
    public function __construct(
        private readonly {Action}Action $action,
    ) {}

    public function handle({Name}DTO $dto): {Entity}
    {
        $entity = $this->action->execute(
            id: $dto->id,
        );

        // Dispatch domain events here if the Entity records them.

        return $entity;
    }
}
