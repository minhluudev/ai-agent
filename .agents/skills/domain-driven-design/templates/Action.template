namespace Modules\{Module}\Domain\Actions;

use Illuminate\Events\Dispatcher;
use Modules\{Module}\Application\DTOs\{Name}DTO;
use Modules\{Module}\Domain\Entities\{Entity};
use Modules\{Module}\Domain\Events\{EventName};
use Modules\{Module}\Domain\Repositories\{Entity}Repository;

class {Action}Action
{
    public function __construct(
        private readonly {Entity}Repository $repository,
        private readonly Dispatcher $events,
    ) {}

    public function execute({Name}DTO $dto): {Entity}
    {
        $entity = $this->repository->find($dto->id);

        // Core business logic lives here.
        // Call only components inside the same Domain from here.

        $this->repository->save($entity);

        // Emit a Domain Event for cross-domain side effects.
        $this->events->dispatch(new {EventName}(
            entityId: $entity->id,
        ));

        return $entity;
    }
}
