type Env = {
  NEXT_PUBLIC_API_BASE_URL: string;
};

const getEnv = (): Env => {
  const apiBaseUrl = process.env.NEXT_PUBLIC_API_BASE_URL;

  if (!apiBaseUrl) {
    throw new Error("Missing NEXT_PUBLIC_API_BASE_URL");
  }

  return {
    NEXT_PUBLIC_API_BASE_URL: apiBaseUrl,
  };
};

export const env = getEnv();
